{
  "name": "pharmadesk-backend",
  "version": "1.0.0",
  "description": "PharmaDesk Backend API",
  "main": "server.js",
  "scripts": {
    "preinstall": "node ../scripts/check-node-version.js",
    "db:init": "node scripts/init-db.js",
    "db:seed": "node scripts/seed-db.js",
    "db:remove-demo": "node scripts/remove-demo-data.js",
    "db:setup": "npm run db:init && npm run db:seed",
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
